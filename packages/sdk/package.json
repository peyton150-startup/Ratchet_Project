{
  "name": "@workspace/sdk",
  "version": "0.0.1",
  "description": "Ratchet TypeScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./signing": {
      "types": "./dist/signing.d.ts",
      "default": "./dist/signing.js"
    }
  },
  "typesVersions": {
    "*": {
      "signing": [
        "dist/signing.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test test/sdk.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
